rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'motaem23y@gmail.com';
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation helper for Product
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'updatedAt'])
        && data.name is map
        && data.price is number
        && data.updatedAt is timestamp;
    }

    // Validation helper for Order
    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'customerEmail', 'customerPhone', 'address', 'paymentMethod', 'items', 'total', 'shippingFee', 'status', 'createdAt'])
        && data.customerName is string && data.customerName.size() <= 200
        && data.customerEmail is string && data.customerEmail.size() <= 200
        && data.customerPhone is string && data.customerPhone.size() <= 32
        && data.address is string && data.address.size() <= 1000
        && data.paymentMethod in ['insta', 'cash']
        && data.items is list && data.items.size() > 0
        && data.total is number && data.total >= 0
        && data.shippingFee is number && data.shippingFee >= 0
        && data.status in ['pending', 'completed', 'cancelled']
        && data.createdAt is timestamp;
    }

    // Validation helper for Review
    function isValidReview(data) {
      return data.keys().hasAll(['userName', 'rating', 'comment', 'createdAt'])
        && data.userName is string && data.userName.size() <= 200
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 1000
        && data.createdAt is timestamp;
    }

    match /products/{productId} {
      allow list, get: if true;
      allow create, update: if isAdmin() && isValidProduct(incoming()) && incoming().updatedAt == request.time;
      allow delete: if isAdmin();

      match /reviews/{reviewId} {
        allow list, get: if true;
        allow create: if isSignedIn() && isValidReview(incoming()) && incoming().createdAt == request.time;
        allow update, delete: if isAdmin();
      }
    }

    match /orders/{orderId} {
      allow list: if isAdmin();
      allow get: if isAdmin() || (isSignedIn() && (resource.data.customerEmail == request.auth.token.email || resource.data.customerEmail == request.auth.email));
      allow create: if isSignedIn() && isValidOrder(incoming()) && incoming().createdAt == request.time && incoming().status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    match /carts/{cartId} {
      allow read, write: if isSignedIn() && (cartId == request.auth.uid || (resource != null && resource.data.userId == request.auth.uid));
    }
  }
}
