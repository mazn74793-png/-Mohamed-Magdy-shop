rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isVerified() && (
        request.auth.token.email == 'motaem23y@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'updatedAt'])
        && data.name is map 
        && data.price is number;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'customerEmail', 'customerPhone', 'address', 'paymentMethod', 'items', 'total', 'shippingFee', 'status', 'createdAt'])
        && data.customerName is string
        && (data.customerEmail == request.auth.token.email || isAdmin())
        && data.paymentMethod in ['insta', 'cash']
        && data.items is list
        && data.total is number
        && data.status in ['pending', 'processing', 'shipped', 'completed', 'cancelled']
        && data.createdAt is timestamp;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['userName', 'rating', 'comment', 'createdAt', 'userId'])
        && data.userId == request.auth.uid
        && data.rating is number && data.rating >= 1 && data.rating <= 5;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'read', 'createdAt'])
        && data.userId is string
        && data.title is map
        && data.message is map
        && data.read is bool
        && data.createdAt is timestamp;
    }

    // --- Collection Matches ---

    match /products/{productId} {
      allow list, get: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() 
                    || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['stock']));
      allow delete: if isAdmin();

      match /reviews/{reviewId} {
        allow list, get: if true;
        allow create: if isVerified() && isValidReview(incoming());
        allow update, delete: if isAdmin() || isOwner(existing().userId);
      }
    }

    match /orders/{orderId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.customerEmail == request.auth.token.email);
      allow get: if isAdmin() || (isSignedIn() && resource.data.customerEmail == request.auth.token.email);
      allow create: if isVerified() && isValidOrder(incoming()) && incoming().status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    match /carts/{cartId} {
      allow read, write: if isOwner(cartId);
    }

    match /notifications/{notificationId} {
      allow list, get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin() && isValidNotification(incoming());
      allow update: if (isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']))
                    || isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /admins/{adminUid} {
      allow get: if isSignedIn() && (request.auth.uid == adminUid || isAdmin());
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId);
    }

    match /test/connection {
      allow get: if true;
    }
  }
}
