{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A fashion product item in the Eleven Eleven store.",
      "type": "object",
      "properties": {
        "name": {
          "type": "object",
          "properties": {
            "EN": { "type": "string" },
            "AR": { "type": "string" }
          },
          "required": ["EN", "AR"]
        },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "category": {
          "type": "object",
          "properties": {
            "EN": { "type": "string" },
            "AR": { "type": "string" }
          },
          "required": ["EN", "AR"]
        },
        "categoryKey": { "type": "string" },
        "img": { "type": "string" },
        "isNew": { "type": "boolean" },
        "isSale": { "type": "boolean" },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "object" },
              "stock": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "img"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "completed", "cancelled"] },
        "adminMessage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerEmail", "items", "total", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user about their order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "object" },
        "message": { "type": "object" },
        "orderId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "A user with administrative privileges.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "uid": { "type": "string" },
        "addedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "uid", "addedBy", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A registered user in the platform.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "displayName"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings and social links.",
      "type": "object",
      "properties": {
        "facebook": { "type": "string" },
        "instagram": { "type": "string" },
        "tiktok": { "type": "string" },
        "whatsapp": { "type": "string" }
      }
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A discount coupon code.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "minOrder": { "type": "number" },
        "usageLimit": { "type": "number" },
        "usedCount": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["code", "type", "value", "isActive"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all products in the store."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of all customer orders."
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Application settings (usually a single 'global' doc)."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of user notifications."
    },
    "/admins/{adminUid}": {
      "schema": "Admin",
      "description": "Collection of authorized administrators."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of all registered users."
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Collection of discount coupons."
    }
  }
}
